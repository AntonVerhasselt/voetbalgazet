# Neon (read-only). Injected into the sandbox as DATABASE_URL / NEON_DATABASE_URL.
NEON_DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Shared secret for Convex / Next waiter invocations (Phase D). Prefer Vercel OIDC in prod.
# When set, Authorization: Bearer <token> is accepted on the eve HTTP channel.
EVE_INVOKE_TOKEN=

# Optional: AI Gateway / provider credentials for local `eve dev` outside Vercel OIDC.
# On Vercel, AI Gateway auth uses OIDC — no provider keys needed for zai/glm-5.2.
