# Convex development (the CLI writes the deployment values to .env.local).
# Cloud Agents: set CONVEX_DEPLOY_KEY as a Cursor secret (not interactive login).
# See docs/cloud-agent-auth.md
CONVEX_DEPLOY_KEY=
CONVEX_AGENT_MODE=anonymous
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Better Auth values are configured on the Convex deployment.
SITE_URL=http://localhost:3000
BETTER_AUTH_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ADMIN_BOOTSTRAP_ROLE_MAP={"redactie@example.be":"admin"}

# Keystatic hosted editing (GitHub App) — see docs/keystatic-admin.md
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=
# Optional: read draft branches for preview in hosted environments
KEYSTATIC_GITHUB_READER_TOKEN=
# Comma-separated exact branches or prefixes (default: master,main,content/)
KEYSTATIC_PREVIEW_BRANCH_PREFIXES=master,main,content/

# Agent access (Cursor Cloud / local agents only). Leave unset in production.
# Same value must also be set on the Convex deployment for prepareAgentSession.
# Length ≥ 32. Never commit the real secret.
AGENT_ACCESS_SECRET=

# Resend + R2 live in the Convex deployment environment (not Next.js):
# RESEND_API_KEY, RESEND_WEBHOOK_SECRET, R2_BUCKET, R2_ENDPOINT,
# R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY, R2_TOKEN
# Optional production guard for live audience sends:
# NEWSLETTER_LIVE_SEND=true

# PostHog Cloud EU (public analytics — cookieless, no session replay)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Optional: private source-map upload during production builds
# POSTHOG_PERSONAL_API_KEY=
# POSTHOG_CLI_ENV_ID=

# Neon (Postgres) — research agent sandbox + taxonomy mapping (read-only user)
# NEON_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Pipeline research mode on the Convex deployment (see convex/lib/pipelineMode.ts):
#   fixture — local/dev sample ideas (not allowed in production)
#   eve — live research-idea agent
# PIPELINE_RESEARCH_MODE=fixture

# Eve research-idea agent (required when PIPELINE_RESEARCH_MODE=eve). Set on Convex.
# EVE_AGENT_URL=https://your-agent.workers.dev
# EVE_INVOKE_TOKEN=

# Research idea agent local package — see apps/agents/research-idea-agent/.env.example
# NEON_DATABASE_URL=
# EVE_INVOKE_TOKEN=