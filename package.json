{
  "name": "de-voetbalgazet",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspace web",
    "dev": "npm run dev --workspace web",
    "dev:convex": "CONVEX_AGENT_MODE=anonymous convex dev",
    "lint": "npm run lint --workspace web && eslint convex",
    "test": "vitest run",
    "typecheck": "npm run typecheck --workspace web && tsc --noEmit -p convex/tsconfig.json"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.12.5",
    "better-auth": "1.6.23",
    "convex": "^1.42.1",
    "convex-helpers": "^0.1.120"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^2.0.0",
    "eslint": "^9.39.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
